<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.qingweico.modules.bill.mapper.BillCategoryMapper">

    <!-- 根据类型查询分类列表 -->
    <select id="selectByType" resultType="cn.qingweico.modules.bill.entity.BillCategory">
        SELECT * FROM bill_category
        WHERE category_type = #{categoryType}
        ORDER BY sort_order ASC, created DESC
    </select>

</mapper>


